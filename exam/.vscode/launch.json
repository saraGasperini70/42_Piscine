	"version": "0.2.0",
	"configurations": [
	{
		"name": "bsq",
		"type": "cppdbg",
		"request": "launch",
		"program": "${workspaceFolder}/exam_rank_05/bsq/bsq",
		"args": ["${workspaceFolder}/exam_rank_05/bsq/map.txt"],
		"stopAtEntry": false,
		"cwd": "${workspaceFolder}",
		"environment": [],
		"externalConsole": false,
		"MIMode": "gdb",
		"preLaunchTask": "build bsq",
		"setupCommands": [
			{
				"description": "Enable pretty-printing for gdb",
				"text": "-enable-pretty-printing",
				"ignoreFailures": true
			}
		]
	}

	]
}
